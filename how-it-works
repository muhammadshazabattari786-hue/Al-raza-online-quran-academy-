<script>
function toggleMenu(){
document.getElementById('menu').classList.toggle('show');
}
window.onclick = function(event) {
    if (!event.target.matches('.hamburger') && !event.target.matches('.hamburger span')) {
        var dropdown = document.getElementById('menu');
        if (dropdown.classList.contains('show')) {
            dropdown.classList.remove('show');
        }
    }
}

// Scroll Animation
const observer = new IntersectionObserver((entries)=>{
entries.forEach((entry, index)=>{
if(entry.isIntersecting && !entry.target.classList.contains('animated')){
const animClasses = ['animate-left', 'animate-right', 'animate-top', 'animate-bottom'];
const animClass = animClasses[index % 4];
entry.target.classList.add(animClass, 'animated');
}
});
}, {threshold:0.12});

document.querySelectorAll('.steps-section, .features-section, .form-section, .faq-section, .step-card, .feature-box, .faq-item, .page-header').forEach(section=>{
observer.observe(section);
});
</script>

